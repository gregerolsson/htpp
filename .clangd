CompileFlags:
  Add:
    - -std=c++23
    - -Wall
    - -Wextra
    - -Wpedantic

Diagnostics:
  UnusedIncludes: Strict
  ClangTidy:
    Add:
      - modernize-*
      - performance-*
    Remove:
      - readability-magic-numbers
      - readability-identifier-length

InlayHints:
  Enabled: Yes
  ParameterNames: Yes
  DeducedTypes: Yes
